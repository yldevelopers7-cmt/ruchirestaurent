  {name:"Mutton Curry",desc:"Fall-off-the-bone mutton in bold South Indian masala gravy",price:300,img:"https://images.unsplash.com/photo-1574894709920-11b28e7367e3?w=400&q=75"},
  {name:"Mutton Pepper Fry",desc:"Dry-fry mutton tossed with coarse pepper, fennel & shallots",price:350,img:"https://images.unsplash.com/photo-1585937421612-70a008356fbe?w=400&q=75"},
  {name:"Chicken Keema",desc:"Minced chicken cooked with peas, tomatoes & garam masala",price:190,img:"https://images.unsplash.com/photo-1608039755401-742074f0548d?w=400&q=75"},
  {name:"Egg Masala",desc:"Boiled eggs simmered in tangy spiced onion-tomato gravy",price:130,img:"https://images.unsplash.com/photo-1567620832903-9fc6debc209f?w=400&q=75"},
];

// ─── RENDER MENU ─────────────────────────────
function renderGrid(items,containerId,type){
  const g=document.getElementById(containerId);
  items.forEach((it,i)=>{
    const id=type+'_'+i;
    g.innerHTML+=`
    <div class="food-card">
      <div class="food-img">
        <img src="${it.img}" alt="${it.name}" loading="lazy"/>
        <div class="food-img-overlay"></div>
        <div class="food-sym-badge ${type==='veg'?'veg':'nonveg'}"></div>
        <div class="food-price-badge">₹${it.price}</div>
      </div>
      <div class="food-body">
        <div class="food-name">${it.name}</div>
        <div class="food-desc">${it.desc}</div>
        <div class="food-footer">
          <div style="font-size:.78rem;color:var(--text-dim)">${type==='veg'?'Veg':'Non-Veg'}</div>
          <div id="ctrl-${id}">
            <button class="add-btn" onclick="addItem('${id}','${it.name}',${it.price})">+ Add</button>
          </div>
        </div>
      </div>
    </div>`;
  });
}
renderGrid(vegItems,'veg-grid','veg');
renderGrid(nonvegItems,'nonveg-grid','nonveg');

// ─── CART ─────────────────────────────────────
const cart={};
const DELIVERY_FEE=40, FREE_ABOVE=800;

function addItem(id,name,price){
  cart[id]={name,price,qty:(cart[id]?.qty||0)+1};
  updateCtrl(id,cart[id].qty,name,price);
  renderCart();
}
function changeQty(id,d){
  if(!cart[id])return;
  cart[id].qty+=d;
  if(cart[id].qty<=0){delete cart[id];updateCtrl(id,0,'',' ');}
  else updateCtrl(id,cart[id].qty,'','');
  renderCart();
}
function updateCtrl(id,qty,name,price){
  const el=document.getElementById('ctrl-'+id);
  if(!el)return;
  if(!name){const p=id.split('_');const arr=p[0]==='veg'?vegItems:nonvegItems;const it=arr[parseInt(p[1])];name=it.name;price=it.price;}
  if(qty===0){
    el.innerHTML=`<button class="add-btn" onclick="addItem('${id}','${name}',${price})">+ Add</button>`;
  } else {
    el.innerHTML=`<div class="qty-ctrl">
      <button onclick="changeQty('${id}',-1)">−</button>
      <span class="qty-num">${qty}</span>
      <button onclick="changeQty('${id}',1)">+</button>
    </div>`;
  }
}
function renderCart(){
  const box=document.getElementById('cart-box');
  const rows=document.getElementById('cart-rows');
  const sum=document.getElementById('cart-summary');
  const cnt=document.getElementById('cart-count');
  const keys=Object.keys(cart);
  let total=0,items=0;
  keys.forEach(id=>{total+=cart[id].price*cart[id].qty;items+=cart[id].qty;});
  cnt.textContent='('+items+')';
  cnt.style.display=items?'inline':'none';
  if(!keys.length){box.classList.remove('show');return;}
  box.classList.add('show');
  rows.innerHTML=keys.map(id=>`
    <div class="cart-row">
      <span>${cart[id].name} × ${cart[id].qty}</span>
      <span>₹${cart[id].price*cart[id].qty}</span>
    </div>`).join('');
  const del=total>=FREE_ABOVE?0:DELIVERY_FEE;
  const grand=total+del;
  sum.innerHTML=`
    <div class="cart-row"><span>Subtotal</span><span>₹${total}</span></div>
    <div class="cart-row"><span>Delivery</span><span>${del===0?'<span class="free-delivery-badge">FREE</span>':'₹'+del}</span></div>
    <div class="cart-row cart-total"><span>Total</span><span>₹${grand}</span></div>
    <p class="del-note">${total<FREE_ABOVE?'Add ₹'+(FREE_ABOVE-total)+' more for free delivery!':'🎉 Free delivery unlocked!'}</p>`;
}
function scrollToCart(){document.getElementById('cart-box').scrollIntoView({behavior:'smooth'});}

// ─── DELIVERY CHECK ───────────────────────────
const R_LAT=13.1007,R_LNG=77.5963,R_KM=20;
function haversine(a,b,c,d){
  const R=6371,dL=(c-a)*Math.PI/180,dl=(d-b)*Math.PI/180;
  const x=Math.sin(dL/2)**2+Math.cos(a*Math.PI/180)*Math.cos(c*Math.PI/180)*Math.sin(dl/2)**2;
  return R*2*Math.atan2(Math.sqrt(x),Math.sqrt(1-x));
}
let deliveryOK=true;
function setDel(ok,msg){
  const dot=document.getElementById('del-dot'),msgEl=document.getElementById('del-msg'),form=document.getElementById('alt-form');
  dot.className='del-dot '+(ok?'ok':'no');
  msgEl.textContent=msg;deliveryOK=ok;
  form.style.display=ok?'none':'block';
}
if(navigator.geolocation){
  navigator.geolocation.getCurrentPosition(p=>{
    const km=haversine(p.coords.latitude,p.coords.longitude,R_LAT,R_LNG);
    km<=R_KM?setDel(true,'✅ We deliver to your location! ('+km.toFixed(1)+' km away)'):setDel(false,'❌ You\'re '+km.toFixed(1)+' km away — outside our 20 km delivery zone.');
  },()=>setDel(true,'📍 Location unavailable — please confirm your delivery address below.'));
}else setDel(true,'📍 Enter your address to confirm delivery.');

function acceptAlt(){
  const v=document.getElementById('alt-input').value.trim();
  if(!v){alert('Please enter an address.');return;}
  document.getElementById('c-addr').value=v;
  setDel(true,'✅ Alternate address accepted — proceed with your order.');
}

// ─── PAYMENT ──────────────────────────────────
function setPay(el,val){
  document.querySelectorAll('.pay-card').forEach(c=>c.classList.remove('sel'));
  el.classList.add('sel');document.getElementById('pay-val').value=val;
}

// ─── ORDER ────────────────────────────────────
function placeOrder(){
  if(!deliveryOK){alert('Please provide an alternate address within our delivery range.');return;}
  const name=document.getElementById('c-name').value.trim();
  const phone=document.getElementById('c-phone').value.trim();
  const addr=document.getElementById('c-addr').value.trim();
  const pay=document.getElementById('pay-val').value;
  if(!name)return alert('Please enter your name.');
  if(!/^\d{10}$/.test(phone))return alert('Please enter a valid 10-digit phone number.');
  if(!addr)return alert('Please enter your delivery address.');
  if(!Object.keys(cart).length)return alert('Your cart is empty! Add items first.');
  if(!pay)return alert('Please select a payment method.');
  let sub=0;Object.values(cart).forEach(i=>sub+=i.price*i.qty);
  const del=sub>=FREE_ABOVE?0:DELIVERY_FEE;
  showModal('🎉','Order Confirmed!',`Thank you, ${name}! Your order of ₹${sub+del} via ${pay} is confirmed. We'll call ${phone} shortly. Estimated delivery: 30–45 minutes.`);
}

// ─── FEEDBACK ─────────────────────────────────
let rating=0;
function setRating(v){
  rating=v;
  document.querySelectorAll('.star').forEach((s,i)=>s.classList.toggle('on',i<v));
}
function sendFeedback(){
  if(!rating)return alert('Please give a star rating.');
  const name=document.getElementById('fb-name').value.trim()||'Anonymous';
  const dish=document.getElementById('fb-dish').value.trim();
  showModal('🙏','Thank You!',`Dear ${name}, your feedback${dish?' about '+dish:''} means the world to us! We'll keep delivering the best to you. See you again at Ruchi!`);
  document.getElementById('fb-name').value='';
  document.getElementById('fb-dish').value='';
  document.getElementById('fb-text').value='';
  setRating(0);
}

// ─── MODAL ────────────────────────────────────
function showModal(icon,title,body){
  document.getElementById('m-icon').textContent=icon;
  document.getElementById('m-title').textContent=title;
  document.getElementById('m-body').textContent=body;
  document.getElementById('modal').classList.add('open');
}
function closeModal(){document.getElementById('modal').classList.remove('open');}

// ─── PARALLAX HERO ────────────────────────────
window.addEventListener('scroll',()=>{
  const bg=document.getElementById('hero-bg');
  if(bg)bg.style.transform=`scale(1.08) translateY(${window.scrollY*0.25}px)`;
  const card=document.getElementById('tilt-card');
  if(card){
    const rect=card.getBoundingClientRect();
    const progress=Math.max(0,Math.min(1,(window.innerHeight-rect.top)/(window.innerHeight+rect.height)));
    const rot=Math.max(0,8-(progress*16));
    card.style.transform=`rotateX(${rot}deg)`;
  }
},{passive:true});
</script>
