<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Ruchi Restaurant – Yelahanka, Bangalore</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#080706;
  --surface:#100e0b;
  --card:#161310;
  --card2:#1c1814;
  --gold:#c8922a;
  --gold-light:#e8b84b;
  --gold-dim:#8a6318;
  --cream:#f0e6cc;
  --ember:#b03020;
  --ember-dark:#7a1e10;
  --green:#2a6e2a;
  --text:#e8dcc8;
  --text-muted:#8a7e68;
  --text-dim:#5a5040;
  --border:#232018;
  --border-light:#2e2820;
  --r:14px;
  --r-lg:20px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-font-smoothing:antialiased}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;overflow-x:hidden}
img{display:block;object-fit:cover}

/* ─── SCROLL HERO ─────────────────────────── */
.scroll-hero{
  height:100vh;min-height:600px;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  position:relative;overflow:hidden;
  padding:2rem;text-align:center;
}
.hero-bg{
  position:absolute;inset:0;
  background:url('https://images.unsplash.com/photo-1555396273-367ea4eb4db5?w=1600&q=80') center/cover no-repeat;
  transform:scale(1.08);
  transition:transform 0s;
  will-change:transform;
}
.hero-overlay{
  position:absolute;inset:0;
  background:linear-gradient(180deg,rgba(8,7,6,.55) 0%,rgba(8,7,6,.82) 60%,rgba(8,7,6,1) 100%);
}
.hero-content{position:relative;z-index:2;max-width:800px}
.hero-eyebrow{
  display:inline-flex;align-items:center;gap:.5rem;
  background:rgba(200,146,42,.12);border:1px solid rgba(200,146,42,.3);
  color:var(--gold-light);font-size:.72rem;letter-spacing:3px;text-transform:uppercase;
  padding:.4rem 1.1rem;border-radius:50px;margin-bottom:1.8rem;
}
.hero-eyebrow::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--ember);animation:blink 2s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.hero-title{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(3.5rem,10vw,7rem);
  font-weight:700;line-height:.92;
  color:var(--cream);
  letter-spacing:-1px;
  margin-bottom:1rem;
}
.hero-title em{color:var(--gold);font-style:italic}
.hero-sub{font-size:1rem;color:var(--text-muted);letter-spacing:2px;text-transform:uppercase;font-weight:300;margin-bottom:2.2rem}
.hero-cta-row{display:flex;gap:.8rem;justify-content:center;flex-wrap:wrap}
.btn-primary{
  background:var(--gold);color:#000;
  padding:.75rem 2rem;border-radius:50px;
  font-size:.9rem;font-weight:600;text-decoration:none;
  border:none;cursor:pointer;letter-spacing:.5px;
  transition:background .2s,transform .15s;
}
.btn-primary:hover{background:var(--gold-light);transform:translateY(-1px)}
.btn-outline{
  background:transparent;color:var(--cream);
  padding:.75rem 2rem;border-radius:50px;
  font-size:.9rem;font-weight:500;text-decoration:none;
  border:1px solid rgba(240,230,204,.3);cursor:pointer;
  transition:border-color .2s,transform .15s;
}
.btn-outline:hover{border-color:var(--gold);color:var(--gold);transform:translateY(-1px)}
.hero-scroll-hint{
  position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:.4rem;
  color:var(--text-dim);font-size:.72rem;letter-spacing:2px;text-transform:uppercase;
}
.scroll-line{width:1px;height:40px;background:linear-gradient(to bottom,var(--gold-dim),transparent);animation:scrollDown 1.8s infinite}
@keyframes scrollDown{0%{transform:scaleY(0);transform-origin:top}50%{transform:scaleY(1);transform-origin:top}100%{transform:scaleY(1);transform-origin:bottom;opacity:0}}

/* ─── CARD TILT SHOWCASE ────────────────────── */
.showcase-wrap{
  perspective:1200px;
  padding:3rem 1.5rem 4rem;
  max-width:1100px;margin:0 auto;
}
.showcase-card{
  background:var(--card);
  border:1px solid var(--border-light);
  border-radius:24px;
  overflow:hidden;
  transform:rotateX(8deg);
  transform-style:preserve-3d;
  box-shadow:0 60px 120px rgba(0,0,0,.7),0 20px 40px rgba(0,0,0,.5);
  transition:transform .6s cubic-bezier(.22,1,.36,1);
}
.showcase-card:hover{transform:rotateX(0deg)}
.showcase-inner{
  display:grid;grid-template-columns:1fr 1fr;
  min-height:340px;
}
.showcase-img{position:relative;overflow:hidden}
.showcase-img img{width:100%;height:100%;min-height:300px;object-fit:cover}
.showcase-img::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(200,146,42,.15),transparent);
}
.showcase-text{
  padding:2.5rem;
  display:flex;flex-direction:column;justify-content:center;gap:1rem;
  background:linear-gradient(135deg,var(--card2),var(--card));
}
.showcase-label{font-size:.72rem;letter-spacing:3px;text-transform:uppercase;color:var(--gold);font-weight:600}
.showcase-text h2{
  font-family:'Cormorant Garamond',serif;
  font-size:2.2rem;font-weight:700;line-height:1.1;color:var(--cream);
}
.showcase-text p{font-size:.9rem;color:var(--text-muted);line-height:1.7}
.special-note{
  background:rgba(176,48,32,.12);border:1px solid rgba(176,48,32,.3);
  border-radius:10px;padding:.7rem 1rem;
  font-size:.82rem;color:#e08070;line-height:1.5;
}
@media(max-width:680px){
  .showcase-inner{grid-template-columns:1fr}
}

/* ─── NAV ──────────────────────────────────── */
.nav{
  position:sticky;top:0;z-index:100;
  background:rgba(8,7,6,.92);backdrop-filter:blur(16px);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
  padding:.7rem 1.5rem;gap:1rem;
}
.nav-brand{font-family:'Cormorant Garamond',serif;font-size:1.3rem;color:var(--gold);font-weight:700;white-space:nowrap}
.nav-links{display:flex;gap:0;overflow-x:auto}
.nav-links a{
  color:var(--text-muted);text-decoration:none;
  padding:.55rem 1rem;font-size:.82rem;font-weight:500;
  letter-spacing:.8px;text-transform:uppercase;white-space:nowrap;
  border-bottom:2px solid transparent;transition:color .2s,border-color .2s;
}
.nav-links a:hover{color:var(--gold);border-bottom-color:var(--gold)}
.nav-cart-btn{
  background:var(--gold);color:#000;border:none;
  padding:.5rem 1.1rem;border-radius:50px;
  font-size:.82rem;font-weight:600;cursor:pointer;white-space:nowrap;
  flex-shrink:0;transition:background .2s;
}
.nav-cart-btn:hover{background:var(--gold-light)}

/* ─── INFO BAR ─────────────────────────────── */
.info-bar{
  background:var(--surface);border-bottom:1px solid var(--border);
  display:flex;flex-wrap:wrap;gap:.5rem 1.5rem;
  padding:.8rem 1.5rem;font-size:.78rem;color:var(--text-muted);
  justify-content:center;align-items:center;
}
.info-bar a{color:var(--gold);text-decoration:none}
.info-bar span{display:flex;align-items:center;gap:.4rem}

/* ─── DELIVERY STATUS ──────────────────────── */
.del-banner{
  max-width:900px;margin:2rem auto;padding:0 1.2rem;
}
.del-box{
  background:var(--card);border:1px solid var(--border-light);
  border-radius:var(--r);padding:1.1rem 1.4rem;
  display:flex;flex-wrap:wrap;align-items:center;gap:.8rem;
}
.del-dot{width:10px;height:10px;border-radius:50%;background:#444;flex-shrink:0;transition:background .3s}
.del-dot.ok{background:#3ac97a}
.del-dot.no{background:var(--ember)}
.del-dot.spin{background:var(--gold);animation:pulse 1s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
#del-msg{font-size:.88rem;flex:1}
.alt-form{width:100%;margin-top:.8rem;display:none}
.alt-form input{
  width:100%;background:#0a0908;border:1px solid var(--border-light);
  color:var(--text);padding:.65rem 1rem;border-radius:9px;
  font-size:.88rem;font-family:'DM Sans',sans-serif;
  margin-bottom:.6rem;outline:none;
}
.alt-form input:focus{border-color:var(--gold)}
.alt-form button{
  background:var(--gold);color:#000;border:none;
  padding:.6rem 1.4rem;border-radius:8px;font-weight:600;cursor:pointer;
}

/* ─── SECTIONS ─────────────────────────────── */
.section{padding:2.5rem 1.2rem;max-width:960px;margin:0 auto}
.section-head{
  display:flex;align-items:flex-end;justify-content:space-between;
  margin-bottom:1.8rem;flex-wrap:wrap;gap:.5rem;
}
.section-head h2{
  font-family:'Cormorant Garamond',serif;
  font-size:2.2rem;font-weight:700;color:var(--cream);
  border-left:3px solid var(--gold);padding-left:.9rem;line-height:1;
}
.section-head p{font-size:.82rem;color:var(--text-muted)}

/* ─── FOOD GRID ────────────────────────────── */
.cat-label{
  display:inline-flex;align-items:center;gap:.5rem;
  padding:.35rem .9rem;border-radius:50px;
  font-size:.75rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;
  margin-bottom:1.2rem;
}
.veg-label{background:rgba(42,110,42,.18);color:#70d870;border:1px solid rgba(42,110,42,.4)}
.nonveg-label{background:rgba(176,48,32,.15);color:#f08070;border:1px solid rgba(176,48,32,.4)}
.sym{width:14px;height:14px;border-radius:2px;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0}
.sym-v{background:#fff;border:2px solid #2a6e2a}
.sym-v::after{content:'';width:5px;height:5px;border-radius:50%;background:#2a6e2a}
.sym-n{background:#fff;border:2px solid var(--ember)}
.sym-n::after{content:'';border-left:5px solid transparent;border-right:5px solid transparent;border-bottom:8px solid var(--ember);width:0;height:0}

.food-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1.1rem;margin-bottom:3rem}
.food-card{
  background:var(--card);border:1px solid var(--border-light);
  border-radius:var(--r-lg);overflow:hidden;
  display:flex;flex-direction:column;
  transition:border-color .2s,transform .2s,box-shadow .2s;
  cursor:default;
}
.food-card:hover{
  border-color:rgba(200,146,42,.4);
  transform:translateY(-3px);
  box-shadow:0 12px 40px rgba(0,0,0,.4);
}
.food-img{
  position:relative;height:170px;overflow:hidden;flex-shrink:0;
}
.food-img img{width:100%;height:100%;object-fit:cover;transition:transform .4s}
.food-card:hover .food-img img{transform:scale(1.05)}
.food-img-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(16,14,11,.9) 0%,transparent 50%);
}
.food-price-badge{
  position:absolute;top:.7rem;right:.7rem;
  background:rgba(16,14,11,.85);border:1px solid var(--border-light);
  color:var(--gold-light);
  font-family:'Cormorant Garamond',serif;
  font-size:1rem;font-weight:700;
  padding:.25rem .7rem;border-radius:50px;
  backdrop-filter:blur(4px);
}
.food-sym-badge{
  position:absolute;top:.7rem;left:.7rem;
  width:22px;height:22px;border-radius:3px;
  background:#fff;border:2px solid;
  display:flex;align-items:center;justify-content:center;
}
.food-sym-badge.veg{border-color:#2a6e2a}
.food-sym-badge.veg::after{content:'';width:8px;height:8px;border-radius:50%;background:#2a6e2a}
.food-sym-badge.nonveg{border-color:var(--ember)}
.food-sym-badge.nonveg::after{content:'';border-left:6px solid transparent;border-right:6px solid transparent;border-bottom:10px solid var(--ember);width:0;height:0}

.food-body{padding:1rem 1.1rem;flex:1;display:flex;flex-direction:column;gap:.4rem}
.food-name{font-weight:600;font-size:.97rem;color:var(--cream);line-height:1.2}
.food-desc{font-size:.78rem;color:var(--text-muted);line-height:1.55;flex:1}
.food-footer{display:flex;align-items:center;justify-content:space-between;margin-top:.6rem}
.add-btn{
  background:transparent;border:1.5px solid var(--gold-dim);
  color:var(--gold);padding:.35rem .9rem;border-radius:8px;
  font-size:.82rem;font-weight:600;cursor:pointer;
  transition:background .2s,color .2s,border-color .2s;
}
.add-btn:hover{background:var(--gold);color:#000;border-color:var(--gold)}
.qty-ctrl{display:flex;align-items:center;gap:.35rem}
.qty-ctrl button{
  background:var(--card2);border:1px solid var(--gold-dim);color:var(--gold);
  width:26px;height:26px;border-radius:6px;cursor:pointer;font-size:1rem;font-weight:700;
  transition:background .15s;
}
.qty-ctrl button:hover{background:rgba(200,146,42,.2)}
.qty-num{min-width:20px;text-align:center;font-weight:600;font-size:.88rem}

/* ─── CART ─────────────────────────────────── */
.cart-wrap{max-width:960px;margin:0 auto;padding:0 1.2rem 2rem}
.cart-box{
  background:var(--card);border:1px solid var(--border-light);
  border-radius:var(--r-lg);padding:1.5rem;
  display:none;
}
.cart-box.show{display:block}
.cart-title{font-family:'Cormorant Garamond',serif;font-size:1.6rem;color:var(--cream);margin-bottom:1.1rem}
.cart-row{display:flex;justify-content:space-between;align-items:center;padding:.55rem 0;border-bottom:1px solid var(--border);font-size:.9rem}
.cart-row:last-child{border-bottom:none}
.cart-total{font-weight:600;color:var(--gold);font-size:1rem}
.free-delivery-badge{
  display:inline-flex;align-items:center;gap:.4rem;
  background:rgba(42,110,42,.15);border:1px solid rgba(42,110,42,.35);
  color:#70d870;font-size:.75rem;padding:.3rem .7rem;border-radius:50px;
}
.del-note{font-size:.75rem;color:var(--text-dim);margin-top:.5rem}

/* ─── ORDER ────────────────────────────────── */
.order-wrap{background:var(--surface);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:3rem 1.2rem}
.order-inner{max-width:680px;margin:0 auto}
.field{margin-bottom:1.1rem}
.field label{display:block;font-size:.75rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-muted);font-weight:600;margin-bottom:.45rem}
.field input,.field textarea,.field select{
  width:100%;background:var(--card);
  border:1px solid var(--border-light);
  color:var(--text);padding:.8rem 1rem;
  border-radius:10px;font-size:.92rem;font-family:'DM Sans',sans-serif;
  outline:none;transition:border-color .2s;
}
.field input:focus,.field textarea:focus,.field select:focus{border-color:var(--gold)}
.field textarea{resize:vertical;min-height:90px}
.field select option{background:var(--card)}
.pay-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:.8rem;margin-bottom:1.5rem}
.pay-card{
  background:var(--card);border:1.5px solid var(--border-light);
  border-radius:12px;padding:.9rem .7rem;text-align:center;
  cursor:pointer;transition:border-color .2s,background .2s;
}
.pay-card:hover,.pay-card.sel{border-color:var(--gold);background:rgba(200,146,42,.06)}
.pay-icon{font-size:1.6rem;margin-bottom:.3rem}
.pay-name{font-size:.8rem;font-weight:600;color:var(--text-muted)}
.pay-card.sel .pay-name{color:var(--gold)}
.submit-btn{
  width:100%;background:linear-gradient(90deg,var(--gold),var(--gold-light));
  color:#000;border:none;padding:1.05rem;
  border-radius:12px;font-size:1rem;font-weight:700;
  cursor:pointer;letter-spacing:.3px;
  transition:opacity .2s,transform .15s;
}
.submit-btn:hover{opacity:.9;transform:translateY(-1px)}
.pay-label{font-size:.8rem;letter-spacing:1px;text-transform:uppercase;color:var(--text-muted);font-weight:600;margin-bottom:.8rem}

/* ─── FEEDBACK ──────────────────────────────── */
.feedback-wrap{max-width:680px;margin:0 auto;padding:3rem 1.2rem}
.stars-row{display:flex;gap:.5rem;margin-bottom:1rem}
.star{font-size:2rem;color:var(--border-light);cursor:pointer;transition:color .15s,transform .1s;user-select:none}
.star.on{color:var(--gold)}
.star:hover{transform:scale(1.15)}

/* ─── FOOTER ───────────────────────────────── */
footer{
  background:#040302;border-top:1px solid var(--border);
  text-align:center;padding:2rem 1rem;
  color:var(--text-dim);font-size:.8rem;line-height:2;
}
footer strong{color:var(--text-muted)}
footer a{color:var(--gold);text-decoration:none}

/* ─── MODAL ─────────────────────────────────── */
.modal-bg{
  display:none;position:fixed;inset:0;
  background:rgba(0,0,0,.85);z-index:999;
  align-items:center;justify-content:center;padding:1rem;
}
.modal-bg.open{display:flex}
.modal-box{
  background:var(--card2);border:1px solid var(--gold-dim);
  border-radius:20px;padding:2.2rem;
  max-width:420px;width:100%;text-align:center;
}
.modal-icon{font-size:2.5rem;margin-bottom:.8rem}
.modal-box h3{font-family:'Cormorant Garamond',serif;font-size:1.8rem;color:var(--cream);margin-bottom:.7rem}
.modal-box p{font-size:.9rem;color:var(--text-muted);line-height:1.7;margin-bottom:1.4rem}
.modal-close{background:var(--gold);color:#000;border:none;padding:.65rem 2rem;border-radius:50px;font-weight:700;cursor:pointer;font-size:.9rem}

@media(max-width:500px){
  .food-grid{grid-template-columns:1fr}
  .pay-grid{grid-template-columns:1fr 1fr}
  .nav-links{display:none}
}
</style>
</head>
<body>

<!-- ═══ HERO ═══ -->
<div class="scroll-hero" id="home">
  <div class="hero-bg" id="hero-bg"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-eyebrow">🍗 Special for Non-Vegetarian</div>
    <h1 class="hero-title"><em>Ruchi</em><br>Restaurant</h1>
    <p class="hero-sub">Yelahanka · Bangalore · Est. with Love</p>
    <div class="hero-cta-row">
      <a href="#menu" class="btn-primary">View Menu</a>
      <a href="#order" class="btn-outline">Order Now</a>
    </div>
  </div>
  <div class="hero-scroll-hint">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</div>

<!-- ═══ SHOWCASE CARD (tilted scroll reveal) ═══ -->
<div class="showcase-wrap" id="about">
  <div class="showcase-card" id="tilt-card">
    <div class="showcase-inner">
      <div class="showcase-img">
        <img src="https://images.unsplash.com/photo-1631515243349-e0cb75fb8d3a?w=800&q=80" alt="Non-veg special dish"/>
      </div>
      <div class="showcase-text">
        <div class="showcase-label">Our Story</div>
        <h2>Flavours That<br>Stay With You</h2>
        <p>At Ruchi, every dish is slow-cooked with generations of South Indian wisdom — bold spices, fresh ingredients, and the warmth of home.</p>
        <div class="special-note">
          🏆 <strong>Ruchi is especially renowned for Non-Vegetarian cuisine</strong> — marinated overnight, cooked in open fire, served with love.
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ═══ NAV ═══ -->
<nav class="nav">
  <div class="nav-brand">Ruchi</div>
  <div class="nav-links">
    <a href="#menu">Menu</a>
    <a href="#order">Order</a>
    <a href="#feedback">Feedback</a>
    <a href="#contact">Contact</a>
  </div>
  <button class="nav-cart-btn" onclick="scrollToCart()">🛒 Cart <span id="cart-count" style="display:none">(0)</span></button>
</nav>

<!-- ═══ INFO BAR ═══ -->
<div class="info-bar">
  <span>📍 2nd Cross, Hunasamaranahalli, Yelahanka, Bangalore – 562157</span>
  <span>📞 <a href="tel:9880734711">9880734711</a> / <a href="tel:9986868485">9986868485</a></span>
  <span>👨‍🍳 Owner: Yathish C Y</span>
  <span>🛵 Delivery: 20 km range</span>
</div>

<!-- ═══ DELIVERY STATUS ═══ -->
<div class="del-banner">
  <div class="del-box">
    <div class="del-dot spin" id="del-dot"></div>
    <span id="del-msg">Detecting your location…</span>
    <div class="alt-form" id="alt-form">
      <input type="text" id="alt-input" placeholder="Enter alternate delivery address within 20 km of Yelahanka"/>
      <button onclick="acceptAlt()">Use This Address</button>
    </div>
  </div>
</div>

<!-- ═══ MENU ═══ -->
<div class="section" id="menu">
  <div class="section-head">
    <h2>Our Menu</h2>
    <p>All dishes freshly prepared</p>
  </div>

  <!-- VEG -->
  <div class="cat-label veg-label"><div class="sym sym-v"></div> Vegetarian</div>
  <div class="food-grid" id="veg-grid"></div>

  <!-- NON VEG -->
  <div class="cat-label nonveg-label" style="margin-top:.5rem"><div class="sym sym-n"></div> Non-Vegetarian · Our Speciality ⭐</div>
  <p style="background:rgba(176,48,32,.1);border:1px solid rgba(176,48,32,.3);border-radius:10px;padding:.8rem 1.1rem;font-size:.82rem;color:#e08070;margin-bottom:1.2rem;line-height:1.6">
