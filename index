<script>
// ─── DATA ───────────────────────────────────
const vegItems=[
  {name:"Masala Dosa",desc:"Crispy golden dosa with spiced potato masala & coconut chutney",price:80,img:"https://images.unsplash.com/photo-1589301760014-d929f3979dbc?w=400&q=75"},
