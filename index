  {name:"Veg Biryani",desc:"Fragrant basmati with seasonal vegetables & whole spices",price:150,img:"https://images.unsplash.com/photo-1563379091339-03b21ab4a4f8?w=400&q=75"},
  {name:"Paneer Butter Masala",desc:"Cottage cheese in a velvety tomato-butter-cream gravy",price:180,img:"https://images.unsplash.com/photo-1565557623262-b51c2513a641?w=400&q=75"},
  {name:"Rava Upma",desc:"Semolina with mustard, curry leaves, cashews & vegetables",price:55,img:"https://images.unsplash.com/photo-1723396671127-c965f6b0e05e?w=400&q=75"},
  {name:"Uttapam",desc:"Thick savoury pancake topped with onion, tomato & green chilli",price:90,img:"https://images.unsplash.com/photo-1585937421612-70a008356fbe?w=400&q=75"},
  {name:"Dal Tadka",desc:"Yellow lentils tempered with ghee, cumin, garlic & dried chilli",price:100,img:"https://images.unsplash.com/photo-1505253758473-96b7015fcd40?w=400&q=75"},
  {name:"Curd Rice",desc:"Creamy yogurt rice with mustard tempering & pomegranate",price:70,img:"https://images.unsplash.com/photo-1546549032-9571cd6b27df?w=400&q=75"},
  {name:"Medu Vada (2 pcs)",desc:"Crispy urad dal vadas served with sambar & coconut chutney",price:65,img:"https://images.unsplash.com/photo-1606491956689-2ea866880c84?w=400&q=75"},
];
const nonvegItems=[
  {name:"Chicken Biryani",desc:"Slow-cooked dum biryani with tender chicken & aromatic spices",price:220,img:"https://images.unsplash.com/photo-1701580853830-48ce00cc9ab2?w=400&q=75"},
  {name:"Chicken Curry",desc:"Rich South Indian chicken curry with coconut & curry leaf gravy",price:200,img:"https://images.unsplash.com/photo-1603894584373-5ac82b2ae398?w=400&q=75"},
  {name:"Chicken 65",desc:"Fiery marinated chicken deep-fried to golden perfection",price:230,img:"https://images.unsplash.com/photo-1610057099443-fde8c4d50f91?w=400&q=75"},
  {name:"Pepper Chicken",desc:"Dry-fry chicken with cracked pepper, fennel & curry leaves",price:240,img:"https://images.unsplash.com/photo-1569058242567-93de6f36f8eb?w=400&q=75"},
  {name:"Chicken Ghee Roast",desc:"Mangalorean style roasted chicken in ghee, Byadagi chilli & spices",price:260,img:"https://images.unsplash.com/photo-1659692507898-0b08a3bd86a4?w=400&q=75"},
